<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    This targets file copies the LibLouis translation tables (data files) into the consuming
    project's output directory. These are plain data files that LibLouis opens by path at runtime,
    so they must ship loose on disk (they cannot be a runtimes/native asset and are not bundled into
    a single-file exe). Keeping them as loose, user-replaceable files also satisfies the LGPL
    obligation that the LibLouis tables remain modifiable/replaceable by the end user.

    The native liblouis.dll is NOT handled here — it ships as a normal runtimes/win-x64/native NuGet
    asset and is placed next to the consumer's exe by the SDK / resolved via deps.json, exactly like
    any other native dependency. Wrapper.cs P/Invokes it by bare name ("liblouis").

    Expected output structure:
      $(OutDir)/liblouis.dll            (from runtimes/win-x64/native, handled by the SDK)
      $(OutDir)/LibLouis/tables.json
      $(OutDir)/LibLouis/tables/*.ctb, *.utb, etc.
  -->

  <ItemGroup>
    <!-- Tables metadata -->
    <None Include="$(MSBuildThisFileDirectory)../content/LibLouis/tables.json"
          Condition="Exists('$(MSBuildThisFileDirectory)../content/LibLouis/tables.json')">
      <Link>LibLouis/tables.json</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </None>

    <!-- Translation tables -->
    <None Include="$(MSBuildThisFileDirectory)../content/LibLouis/tables/**/*"
          Condition="Exists('$(MSBuildThisFileDirectory)../content/LibLouis/tables/')">
      <Link>LibLouis/tables/%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Visible>false</Visible>
    </None>
  </ItemGroup>

</Project>
